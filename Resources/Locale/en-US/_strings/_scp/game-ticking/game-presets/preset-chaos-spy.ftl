chaos-spy-round-end-agent-name = chaos spy
chaos-spy-round-end-codewords = The codewords were: [color=White]{$codewords}[/color]

chaos-spy-role-greeting =
    You are an agent acting on behalf of {$corporation} in the service of [color=darkgreen]the Chaos Insurgency[/color].
    Your objectives and codewords are listed in the character menu.
    Use your uplink to buy the tools you will need to complete this mission.
    Death to the Foundation!
chaos-spy-role-codewords =
    The codewords are: [color=lightgray]
    {$codewords}.[/color]
    Codewords can be used in regular conversation to discreetly identify yourself to other Chaos Insurgency agents.
    Listen for them, and keep them secret.
chaos-spy-role-uplink-code =
    Set your ringtone to [color=lightgray]{$code}[/color] to lock or unlock your uplink.
    Remember to lock it afterwards, or facility personnel may gain access to it!
chaos-spy-role-uplink-implant =
    Your uplink implant has been activated. Access it from your hotbar.
    The uplink is secure unless someone removes it from your body.

chaos-spy-role-codewords-short =
    The codewords are:
    {$codewords}.
chaos-spy-role-uplink-code-short = Your uplink code is {$code}. Set it as your PDA ringtone to access your uplink.
chaos-spy-role-uplink-implant-short = Your uplink was implanted. Access it from the action menu.
